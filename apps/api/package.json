{
  "name": "@sealai/api",
  "type": "module",
  "scripts": {
    "dev": "go run github.com/air-verse/air@latest",
    "run": "go run main.go",
    "build": "go build -o main .",
    "test": "go test ./...",
    "fmt": "go fmt ./...",
    "tidy": "go mod tidy",
    "vet": "go vet ./...",
    "clean": "rm -f main",
    "docker:build": "docker build -t sealos-api:latest .",
    "docker:push": "docker push sealos-api:latest"
  }
}
